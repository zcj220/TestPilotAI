{
  "app_name": "TaskPilot Flutter Demo",
  "description": "Flutter登录模块测试：正确账号登录、空账号登录（Bug-1：应拒绝但放行）、错误密码提示。密码明文可见（Bug-2：无obscureText）",
  "base_url": "",
  "version": "2.0",
  "platform": "android",
  "app_package": "com.testpilot.flutter_demo",
  "app_activity": ".MainActivity",
  "pages": [
    {
      "url": "",
      "title": "登录页",
      "elements": {
        "username": "//android.widget.EditText[@hint='tf_username']",
        "password": "//android.widget.EditText[@hint='tf_password']",
        "login_btn": "accessibility_id:btn_login",
        "error_text": "accessibility_id:txt_error"
      },
      "scenarios": [
        {
          "name": "正确账号登录成功",
          "steps": [
            {
              "action": "wait",
              "value": "3000",
              "description": "等待Flutter应用启动渲染"
            },
            {
              "action": "screenshot",
              "value": "login_init"
            },
            {
              "action": "fill",
              "target": "//android.widget.EditText[@hint='tf_username']",
              "value": "admin",
              "description": "输入用户名"
            },
            {
              "action": "fill",
              "target": "//android.widget.EditText[@hint='tf_password']",
              "value": "admin123",
              "description": "输入密码"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_login",
              "description": "点击登录按钮"
            },
            {
              "action": "wait",
              "value": "2000",
              "description": "等待页面跳转和U2恢复"
            },
            {
              "action": "assert_text",
              "target": "accessibility_id:txt_pending",
              "expected": "待办任务",
              "description": "验证已跳转到任务列表页"
            },
            {
              "action": "screenshot",
              "value": "login_success"
            }
          ]
        },
        {
          "name": "空账号应被拒绝（Bug-1：实际会放行）",
          "steps": [
            {
              "action": "navigate",
              "value": "com.testpilot.flutter_demo/.MainActivity",
              "description": "重启回登录页"
            },
            {
              "action": "wait",
              "value": "3000",
              "description": "等待Flutter重新渲染"
            },
            {
              "action": "wait",
              "target": "accessibility_id:btn_login",
              "timeout_ms": 15000,
              "description": "等待登录按钮就绪"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_login",
              "description": "不填任何内容直接点击登录"
            },
            {
              "action": "wait",
              "value": "1500"
            },
            {
              "action": "assert_text",
              "target": "accessibility_id:txt_error",
              "expected": "请输入用户名",
              "description": "【预期失败-Bug-1】空账号应显示错误提示，但实际直接跳转到任务页"
            },
            {
              "action": "screenshot",
              "value": "empty_login_bug1"
            }
          ]
        },
        {
          "name": "错误密码显示错误提示",
          "steps": [
            {
              "action": "navigate",
              "value": "com.testpilot.flutter_demo/.MainActivity",
              "description": "重启回登录页"
            },
            {
              "action": "wait",
              "value": "3000",
              "description": "等待Flutter重新渲染"
            },
            {
              "action": "wait",
              "target": "accessibility_id:btn_login",
              "timeout_ms": 15000,
              "description": "等待登录按钮就绪"
            },
            {
              "action": "fill",
              "target": "//android.widget.EditText[@hint='tf_username']",
              "value": "wronguser",
              "description": "输入错误用户名"
            },
            {
              "action": "fill",
              "target": "//android.widget.EditText[@hint='tf_password']",
              "value": "wrongpass",
              "description": "输入错误密码"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_login",
              "description": "点击登录"
            },
            {
              "action": "wait",
              "value": "1000"
            },
            {
              "action": "assert_text",
              "target": "accessibility_id:txt_error",
              "expected": "用户名或密码错误",
              "description": "验证显示错误提示文本"
            },
            {
              "action": "screenshot",
              "value": "wrong_cred_error"
            }
          ]
        }
      ]
    }
  ]
}