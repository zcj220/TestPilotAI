{
  "app_name": "TaskPilot Flutter Demo",
  "description": "Flutter Android Login Test",
  "base_url": "",
  "version": "1.3",
  "platform": "android",
  "app_package": "com.testpilot.flutter_demo",
  "app_activity": ".MainActivity",
  "pages": [
    {
      "url": "",
      "title": "Login",
      "elements": {
        "username": "uia:new UiSelector().className(\"android.widget.EditText\").clickable(true).instance(0)",
        "password": "uia:new UiSelector().className(\"android.widget.EditText\").clickable(true).instance(1)",
        "login_btn": "accessibility_id:btn_login"
      },
      "scenarios": [
        {
          "name": "正常账号登录成功",
          "steps": [
            {
              "action": "wait",
              "value": "3000",
              "description": "等待应用启动"
            },
            {
              "action": "screenshot",
              "value": "login_init"
            },
            {
              "action": "fill",
              "target": "uia:new UiSelector().className(\"android.widget.EditText\").clickable(true).instance(0)",
              "value": "admin",
              "description": "输入用户名"
            },
            {
              "action": "fill",
              "target": "uia:new UiSelector().className(\"android.widget.EditText\").clickable(true).instance(1)",
              "value": "admin123",
              "description": "输入密码"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_login",
              "description": "点击登录"
            },
            {
              "action": "wait",
              "value": "2000"
            },
            {
              "action": "screenshot",
              "value": "after_login"
            }
          ]
        },
        {
          "name": "空账号应被拒绝",
          "steps": [
            {
              "action": "navigate",
              "value": "com.testpilot.flutter_demo/.MainActivity",
              "description": "重启回登录页"
            },
            {
              "action": "wait",
              "value": "5000",
              "description": "等待Flutter重新渲染"
            },
            {
              "action": "wait",
              "target": "accessibility_id:btn_login",
              "timeout_ms": 15000,
              "description": "等待登录按钮就绪"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_login",
              "description": "空账号直接登录"
            },
            {
              "action": "wait",
              "value": "1000"
            },
            {
              "action": "screenshot",
              "value": "empty_login"
            }
          ]
        },
        {
          "name": "错误账号显示提示",
          "steps": [
            {
              "action": "navigate",
              "value": "com.testpilot.flutter_demo/.MainActivity",
              "description": "重启回登录页"
            },
            {
              "action": "wait",
              "value": "5000",
              "description": "等待Flutter重新渲染"
            },
            {
              "action": "wait",
              "target": "accessibility_id:btn_login",
              "timeout_ms": 15000,
              "description": "等待登录按钮就绪"
            },
            {
              "action": "fill",
              "target": "uia:new UiSelector().className(\"android.widget.EditText\").clickable(true).instance(0)",
              "value": "wronguser",
              "description": "输入错误用户名"
            },
            {
              "action": "fill",
              "target": "uia:new UiSelector().className(\"android.widget.EditText\").clickable(true).instance(1)",
              "value": "wrongpass",
              "description": "输入错误密码"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_login",
              "description": "点击登录"
            },
            {
              "action": "wait",
              "value": "1000"
            },
            {
              "action": "screenshot",
              "value": "wrong_cred"
            }
          ]
        }
      ]
    }
  ]
}