{
  "app_name": "TaskPilot Flutter Demo",
  "description": "测试 Flutter 原生 Android 应用的任务列表模块。覆盖：添加任务、完成任务后计数器变化（Bug-3：显示总数而非待办数）、删除任务、删除最后一项后崩溃（Bug-4）四个场景。",
  "base_url": "",
  "version": "1.0",
  "platform": "android",
  "app_package": "com.testpilot.flutter_demo",
  "app_activity": ".MainActivity",
  "pages": [
    {
      "url": "",
      "title": "任务列表页",
      "scenarios": [
        {
          "name": "登录并查看初始任务列表",
          "steps": [
            {
              "action": "wait",
              "value": "1500",
              "description": "等待应用启动"
            },
            {
              "action": "fill",
              "target": "//android.widget.EditText[@index='0']",
              "value": "admin"
            },
            {
              "action": "fill",
              "target": "//android.widget.EditText[@index='1']",
              "value": "admin123"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_login"
            },
            {
              "action": "wait",
              "value": "1000"
            },
            {
              "action": "screenshot",
              "value": "任务列表初始状态"
            },
            {
              "action": "assert_text",
              "target": "accessibility_id:txt_pending",
              "expected": "待办任务：3 项",
              "description": "验证初始有3条任务"
            }
          ]
        },
        {
          "name": "添加新任务",
          "steps": [
            {
              "action": "fill",
              "target": "//android.widget.EditText[@hint='tf_new_task']",
              "value": "测试新任务",
              "description": "在输入框输入新任务"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_add",
              "description": "点击添加按钮"
            },
            {
              "action": "wait",
              "value": "500"
            },
            {
              "action": "assert_text",
              "target": "accessibility_id:txt_pending",
              "expected": "待办任务：4 项",
              "description": "验证任务总数变为4"
            }
          ]
        },
        {
          "name": "完成任务后计数器应减少（Bug-3）",
          "steps": [
            {
              "action": "click",
              "target": "accessibility_id:chk_task_0",
              "description": "勾选第1个任务为已完成"
            },
            {
              "action": "wait",
              "value": "500"
            },
            {
              "action": "assert_text",
              "target": "accessibility_id:txt_pending",
              "expected": "待办任务：3 项",
              "description": "【预期失败-Bug-3】完成1项后待办应显示3，但实际仍显示4（总数）"
            },
            {
              "action": "screenshot",
              "value": "完成任务后计数器截图"
            }
          ]
        },
        {
          "name": "删除任务功能正常",
          "steps": [
            {
              "action": "click",
              "target": "accessibility_id:btn_delete_1",
              "description": "删除第2个任务"
            },
            {
              "action": "wait",
              "value": "500"
            },
            {
              "action": "assert_text",
              "target": "accessibility_id:txt_pending",
              "expected": "待办任务：3 项",
              "description": "删除一条后剩余3条"
            }
          ]
        },
        {
          "name": "依次删除所有任务直到崩溃（Bug-4）",
          "steps": [
            {
              "action": "click",
              "target": "accessibility_id:btn_delete_0",
              "description": "删除第1项"
            },
            {
              "action": "wait",
              "value": "300"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_delete_0",
              "description": "删除第1项（原第2项）"
            },
            {
              "action": "wait",
              "value": "300"
            },
            {
              "action": "click",
              "target": "accessibility_id:btn_delete_0",
              "description": "删除最后一项"
            },
            {
              "action": "wait",
              "value": "500"
            },
            {
              "action": "screenshot",
              "value": "删除最后一项后截图（Bug-4：可能崩溃）"
            },
            {
              "action": "assert_text",
              "target": "accessibility_id:txt_pending",
              "expected": "待办任务：0 项",
              "description": "【预期失败-Bug-4】删完后应显示0项，但可能崩溃"
            }
          ]
        }
      ]
    }
  ]
}
