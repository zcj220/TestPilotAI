.container { padding: 30rpx; }
.title { font-size: 36rpx; font-weight: bold; margin-bottom: 20rpx; }
.info { font-size: 26rpx; color: #666; margin-bottom: 20rpx; }
.btn { background: #333; color: #fff; padding: 20rpx; border-radius: 12rpx; margin-bottom: 12rpx; text-align: center; font-size: 28rpx; }
.btn.clear { background: #999; }
.log-area { background: #f5f5f5; padding: 20rpx; border-radius: 12rpx; margin-top: 20rpx; min-height: 300rpx; font-size: 22rpx; font-family: monospace; white-space: pre-wrap; word-break: break-all; }
