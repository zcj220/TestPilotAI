# ═══════════════════════════════════════════════════════
#  TestPilot AI — 环境变量配置
# ═══════════════════════════════════════════════════════
#
#  使用方式：cp .env.example .env && 编辑 .env
#  注意：.env 文件已在 .gitignore 中，不会被提交
#
# ── 数据库 ──────────────────────────────────────
# 本地开发可不设置（默认使用 SQLite）
# MySQL（阿里云 RDS）：
# DATABASE_URL=mysql+pymysql://用户名:密码@主机:3306/数据库名?charset=utf8mb4
# PostgreSQL：
# DATABASE_URL=postgresql://用户名:密码@主机:5432/数据库名
DATABASE_URL=

# ── 认证 ────────────────────────────────────────
# JWT 签名密钥（必须设置，建议 32+ 位随机字符串）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=changeme_generate_with_secrets_module

# ── AI 服务 ─────────────────────────────────────
# 方舟平台 API 密钥（不配置则 AI 测试功能不可用）
TP_AI_API_KEY=
TP_AI_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TP_AI_MODEL=doubao-seed-1-8-251228
TP_AI_REASONING_EFFORT=medium

# ── 服务器 ──────────────────────────────────────
TP_SERVER_HOST=0.0.0.0
TP_SERVER_PORT=8900
TP_SERVER_LOG_LEVEL=INFO

# ── 邮件验证码 ──────────────────────────────────
# 注册时发送验证码邮件（不配置则走开发模式，验证码直接返回在 API 响应中）
# REQUIRE_EMAIL_VERIFICATION=true   ← 上线前改为 true
REQUIRE_EMAIL_VERIFICATION=false
#
# 企业邮 SMTP（以腾讯企业邮为例）
# SMTP_HOST=smtp.exmail.qq.com         # 腾讯企业邮
# SMTP_HOST=smtp.mxhichina.com         # 阿里云企业邮
# SMTP_PORT=465                        # 465=SSL, 587=TLS/STARTTLS
# SMTP_USER=no-reply@xinzaoai.com
# SMTP_PASS=邮箱密码或授权码
# SMTP_FROM=no-reply@xinzaoai.com      # 默认等于 SMTP_USER，可省略
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── 支付（预留） ────────────────────────────────
PAYMENT_WEBHOOK_SECRET=

# ── 管理后台 ────────────────────────────────────
ADMIN_INITIAL_PASSWORD=changeme_admin_2026
