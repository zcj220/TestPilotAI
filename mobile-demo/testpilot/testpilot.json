{
  "app_name": "鲜果坊 移动商城",
  "description": "移动端H5水果商城深度测试：覆盖登录注册、商品浏览分类搜索、购物车增删改、结算配送、订单查看、个人中心，含安全审计和逻辑漏洞挖掘",
  "base_url": "http://localhost:8900/preview/mobile-demo/",
  "version": "2.0",
  "platform": "android",
  "pages": [
    {
      "url": "/",
      "title": "登录页",
      "elements": {
        "手机号输入": "#loginPhone",
        "密码输入": "#loginPass",
        "登录按钮": "#loginBtn",
        "登录错误提示": "#loginError",
        "随便逛逛": "#guestBtn",
        "注册链接": "#registerLink"
      },
      "scenarios": [
        {
          "name": "登录-正常登录",
          "description": "输入正确手机号和密码，验证登录成功跳转到首页",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "assert_visible", "target": "#tabHome", "description": "验证跳转到首页"},
            {"action": "assert_visible", "target": ".product-card", "description": "验证商品列表显示"}
          ]
        },
        {
          "name": "登录-空手机号",
          "description": "不输入手机号直接登录",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "assert_text", "target": "#loginError", "expected": "请输入手机号"}
          ]
        },
        {
          "name": "登录-手机号格式错误",
          "description": "输入格式错误的手机号",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "abc123"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "assert_text", "target": "#loginError", "expected": "手机号格式不正确"}
          ]
        },
        {
          "name": "登录-空密码",
          "description": "输入手机号但不输入密码",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "assert_text", "target": "#loginError", "expected": "请输入密码"}
          ]
        },
        {
          "name": "登录-密码太短",
          "description": "密码少于6位",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "fill", "target": "#loginPass", "value": "123"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "assert_text", "target": "#loginError", "expected": "密码至少6位"}
          ]
        },
        {
          "name": "登录-错误密码",
          "description": "输入错误密码验证提示",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "fill", "target": "#loginPass", "value": "wrongpw"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "assert_text", "target": "#loginError", "expected": "密码错误"}
          ]
        },
        {
          "name": "【安全审计】认证绕过-任意手机号+万能密码",
          "description": "代码审计发现doLogin()只校验密码是否为123456或password，不验证手机号是否注册。用从未注册的手机号+123456测试",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13999999999"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "assert_visible", "target": "#tabHome", "description": "【认证漏洞】未注册的13999999999用123456成功登录，说明没有用户数据库校验"},
            {"action": "screenshot", "description": "记录认证绕过证据"}
          ]
        },
        {
          "name": "登录-游客模式",
          "description": "点击随便逛逛进入首页",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "assert_visible", "target": "#tabHome"},
            {"action": "assert_visible", "target": ".product-card"}
          ]
        }
      ]
    },
    {
      "url": "/register",
      "title": "注册页",
      "elements": {
        "手机号": "#regPhone",
        "昵称": "#regNickname",
        "密码": "#regPass",
        "确认密码": "#regPass2",
        "注册按钮": "#regSubmitBtn",
        "返回按钮": "#regBackBtn",
        "注册错误提示": "#regError"
      },
      "scenarios": [
        {
          "name": "注册-正常注册",
          "description": "完整注册流程",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#registerLink"},
            {"action": "assert_visible", "target": "#registerPage"},
            {"action": "fill", "target": "#regPhone", "value": "13900139000"},
            {"action": "fill", "target": "#regNickname", "value": "测试用户"},
            {"action": "fill", "target": "#regPass", "value": "test123456"},
            {"action": "fill", "target": "#regPass2", "value": "test123456"},
            {"action": "click", "target": "#regSubmitBtn"},
            {"action": "assert_visible", "target": "#tabHome", "description": "注册后自动登录跳转首页"}
          ]
        },
        {
          "name": "注册-两次密码不一致",
          "description": "两次密码不同",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#registerLink"},
            {"action": "fill", "target": "#regPhone", "value": "13900139000"},
            {"action": "fill", "target": "#regNickname", "value": "测试"},
            {"action": "fill", "target": "#regPass", "value": "test123456"},
            {"action": "fill", "target": "#regPass2", "value": "different99"},
            {"action": "click", "target": "#regSubmitBtn"},
            {"action": "assert_text", "target": "#regError", "expected": "两次密码不一致"}
          ]
        },
        {
          "name": "注册-返回登录",
          "description": "点返回按钮",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#registerLink"},
            {"action": "assert_visible", "target": "#registerPage"},
            {"action": "click", "target": "#regBackBtn"},
            {"action": "assert_visible", "target": "#loginPage"}
          ]
        }
      ]
    },
    {
      "url": "/home",
      "title": "首页-商品浏览",
      "elements": {
        "搜索框": "#searchInput",
        "搜索按钮": "#searchBtn",
        "全部分类": "#catAll",
        "水果分类": "#catFruit",
        "蔬菜分类": "#catVeg",
        "零食分类": "#catSnack",
        "商品列表": "#productList"
      },
      "scenarios": [
        {
          "name": "首页-商品列表+数据验证",
          "description": "验证商品名称、价格、库存正确显示",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "assert_visible", "target": ".product-card"},
            {"action": "assert_text", "target": "#pname-1", "expected": "红富士苹果"},
            {"action": "assert_text", "target": "#pname-2", "expected": "进口香蕉"},
            {"action": "assert_text", "target": "#pstock-3", "expected": "已售罄"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "首页-分类筛选水果",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#catFruit"},
            {"action": "assert_visible", "target": "#product-1"},
            {"action": "assert_visible", "target": "#product-2"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "首页-分类筛选蔬菜",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#catVeg"},
            {"action": "assert_visible", "target": "#product-5"},
            {"action": "assert_visible", "target": "#product-6"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "首页-分类筛选零食",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#catSnack"},
            {"action": "assert_visible", "target": "#product-7"},
            {"action": "assert_visible", "target": "#product-8"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "首页-搜索商品",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "fill", "target": "#searchInput", "value": "苹果"},
            {"action": "click", "target": "#searchBtn"},
            {"action": "assert_visible", "target": "#product-1"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "首页-搜索无结果",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "fill", "target": "#searchInput", "value": "榴莲"},
            {"action": "click", "target": "#searchBtn"},
            {"action": "assert_text", "target": "#noResult", "expected": "没有找到相关商品"}
          ]
        },
        {
          "name": "首页-售罄商品不可购买",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "assert_text", "target": "#pstock-3", "expected": "已售罄"},
            {"action": "assert_text", "target": "#addBtn-3", "expected": "已售罄"}
          ]
        }
      ]
    },
    {
      "url": "/cart",
      "title": "购物车",
      "scenarios": [
        {
          "name": "购物车-空状态",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#navCart"},
            {"action": "assert_visible", "target": "#cartEmpty"},
            {"action": "assert_text", "target": ".empty-text", "expected": "购物车是空的"}
          ]
        },
        {
          "name": "购物车-加入商品+总价验证",
          "description": "加入苹果12.80+香蕉6.50，验证总价19.30",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "assert_text", "target": "#cartBadge", "expected": "1"},
            {"action": "click", "target": "#addBtn-2"},
            {"action": "assert_text", "target": "#cartBadge", "expected": "2"},
            {"action": "click", "target": "#navCart"},
            {"action": "assert_visible", "target": "#cartItem-1"},
            {"action": "assert_visible", "target": "#cartItem-2"},
            {"action": "assert_text", "target": "#cartTotal", "expected": "19.30"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "购物车-修改数量",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#navCart"},
            {"action": "assert_text", "target": "#qty-1", "expected": "1"},
            {"action": "assert_text", "target": "#cartTotal", "expected": "12.80"},
            {"action": "click", "target": "#cartItem-1 .qty-btn:last-of-type"},
            {"action": "assert_text", "target": "#qty-1", "expected": "2"},
            {"action": "assert_text", "target": "#cartTotal", "expected": "25.60"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "【安全审计】浮点精度-多商品总价",
          "description": "代码用纯浮点加法total+=price*qty，12.8+6.5+6.5可能=25.799999而非25.80",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#addBtn-2"},
            {"action": "click", "target": "#addBtn-2"},
            {"action": "click", "target": "#navCart"},
            {"action": "assert_text", "target": "#cartTotal", "expected": "25.80", "description": "12.8+6.5*2应为25.80，浮点精度可能导致25.799999"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "【安全审计】库存边界-超量加购",
          "description": "苹果库存50，代码addToCart只检查stock>0不检查已加数量，可无限加购",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#navCart"},
            {"action": "assert_text", "target": "#qty-1", "expected": "3"},
            {"action": "click", "target": "#navHome"},
            {"action": "assert_text", "target": "#addBtn-1", "expected": "再来一份(已加3)", "description": "按钮显示已加3，但无库存上限校验可无限加"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "购物车-清空",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#addBtn-2"},
            {"action": "click", "target": "#navCart"},
            {"action": "assert_text", "target": "#cartItemCount", "expected": "2"},
            {"action": "click", "target": "#cartClearBtn"},
            {"action": "assert_visible", "target": "#cartEmpty"}
          ]
        },
        {
          "name": "购物车-游客结算拦截",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#navCart"},
            {"action": "click", "target": "#checkoutBtn"},
            {"action": "assert_visible", "target": "#loginPage"}
          ]
        }
      ]
    },
    {
      "url": "/checkout",
      "title": "结算页",
      "scenarios": [
        {
          "name": "结算-完整下单（端到端）",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#addBtn-2"},
            {"action": "click", "target": "#navCart"},
            {"action": "click", "target": "#checkoutBtn"},
            {"action": "assert_visible", "target": "#checkoutPage"},
            {"action": "fill", "target": "#addrName", "value": "张三"},
            {"action": "fill", "target": "#addrPhone", "value": "13800138000"},
            {"action": "fill", "target": "#addrDetail", "value": "北京市朝阳区建国路88号"},
            {"action": "assert_text", "target": "#checkoutSubtotal", "expected": "19.30"},
            {"action": "assert_text", "target": "#checkoutDelivery", "expected": "8.00"},
            {"action": "click", "target": "#submitOrderBtn"},
            {"action": "assert_visible", "target": "#orderResultPage"},
            {"action": "assert_text", "target": "#resultTitle", "expected": "下单成功"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "结算-空姓名校验",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#navCart"},
            {"action": "click", "target": "#checkoutBtn"},
            {"action": "click", "target": "#submitOrderBtn"},
            {"action": "assert_text", "target": "#checkoutError", "expected": "请输入收货人姓名"}
          ]
        },
        {
          "name": "【安全审计】配送费-到店自提应免费",
          "description": "代码selfpick的deliveryFee=3而非0，但页面显示免费。验证实付金额是否包含隐藏运费",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#navCart"},
            {"action": "click", "target": "#checkoutBtn"},
            {"action": "assert_text", "target": "#checkoutSubtotal", "expected": "12.80"},
            {"action": "click", "target": "#deliverySelf"},
            {"action": "assert_text", "target": "#checkoutDelivery", "expected": "免费"},
            {"action": "assert_text", "target": "#checkoutTotal", "expected": "7.80", "description": "自提免运费+首单减5：12.80-5=7.80。若显示15.80说明自提收了3元且优惠没生效"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "【安全审计】优惠券-首单减5元验证",
          "description": "Banner写新用户首单立减5元，代码discount=5但total=subtotal+deliveryFee没减discount",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "click", "target": "#addBtn-1"},
            {"action": "click", "target": "#navCart"},
            {"action": "click", "target": "#checkoutBtn"},
            {"action": "assert_text", "target": "#checkoutSubtotal", "expected": "12.80"},
            {"action": "assert_text", "target": "#checkoutDiscount", "expected": "-5.00"},
            {"action": "assert_text", "target": "#checkoutDelivery", "expected": "8.00"},
            {"action": "assert_text", "target": "#checkoutTotal", "expected": "15.80", "description": "12.80+8-5=15.80。若显示20.80说明优惠没生效"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "【安全审计】优惠+自提组合",
          "description": "同时自提+首单优惠：番茄5.50+0运费-5优惠=0.50",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "click", "target": "#addBtn-6"},
            {"action": "click", "target": "#navCart"},
            {"action": "click", "target": "#checkoutBtn"},
            {"action": "click", "target": "#deliverySelf"},
            {"action": "assert_text", "target": "#checkoutSubtotal", "expected": "5.50"},
            {"action": "assert_text", "target": "#checkoutDelivery", "expected": "免费"},
            {"action": "assert_text", "target": "#checkoutDiscount", "expected": "-5.00"},
            {"action": "assert_text", "target": "#checkoutTotal", "expected": "0.50", "description": "5.50+0-5=0.50。若8.50说明自提和优惠都没生效"},
            {"action": "screenshot"}
          ]
        }
      ]
    },
    {
      "url": "/me",
      "title": "个人中心",
      "scenarios": [
        {
          "name": "个人中心-登录后信息",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "fill", "target": "#loginPhone", "value": "13800138000"},
            {"action": "fill", "target": "#loginPass", "value": "123456"},
            {"action": "click", "target": "#loginBtn"},
            {"action": "click", "target": "#navMe"},
            {"action": "assert_text", "target": "#userName", "expected": "用户8000"},
            {"action": "assert_text", "target": "#userPhone", "expected": "13800138000"},
            {"action": "assert_text", "target": "#couponCount", "expected": "2"},
            {"action": "assert_visible", "target": "#logoutBtn"},
            {"action": "screenshot"}
          ]
        },
        {
          "name": "个人中心-游客模式",
          "steps": [
            {"action": "navigate", "value": "http://localhost:8900/preview/mobile-demo/"},
            {"action": "click", "target": "#guestBtn"},
