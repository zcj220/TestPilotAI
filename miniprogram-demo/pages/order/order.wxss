.container { padding: 40rpx; text-align: center; }
.success-icon { font-size: 100rpx; margin-bottom: 16rpx; }
.success-title { font-size: 36rpx; font-weight: bold; color: #38a169; margin-bottom: 40rpx; }
.order-info { background: #fff; border-radius: 12rpx; padding: 24rpx; text-align: left; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05); }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 28rpx; border-bottom: 1rpx solid #f5f5f5; }
.info-row.total { border-bottom: none; border-top: 2rpx solid #eee; padding-top: 16rpx; margin-top: 8rpx; }
.info-label { color: #666; }
.info-value { color: #333; font-weight: bold; }
.info-value.price { color: #e53e3e; font-size: 36rpx; }
.btn-home { display: inline-block; margin-top: 40rpx; background: #2d8cf0; color: #fff; padding: 20rpx 60rpx; border-radius: 40rpx; font-size: 30rpx; }
