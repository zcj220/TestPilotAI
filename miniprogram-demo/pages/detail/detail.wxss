.container { padding: 30rpx; }
.detail-img { font-size: 120rpx; text-align: center; margin: 20rpx 0; }
.detail-name { font-size: 36rpx; font-weight: bold; }
.detail-cat { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.detail-price { font-size: 40rpx; color: #e53e3e; font-weight: bold; margin-top: 16rpx; }
.detail-vip { font-size: 28rpx; color: #d4a017; background: #fff8e1; padding: 8rpx 16rpx; border-radius: 8rpx; margin-top: 8rpx; display: inline-block; }
.detail-stock { font-size: 26rpx; color: #666; margin-top: 12rpx; }
.detail-actions { display: flex; margin-top: 30rpx; gap: 16rpx; }
.btn-primary { flex: 1; background: #2d8cf0; color: #fff; padding: 20rpx; border-radius: 12rpx; text-align: center; font-size: 30rpx; }
.btn-secondary { flex: 1; background: #f0f0f0; color: #333; padding: 20rpx; border-radius: 12rpx; text-align: center; font-size: 30rpx; }
.msg { text-align: center; margin-top: 20rpx; font-size: 26rpx; padding: 12rpx; border-radius: 8rpx; }
.msg.success { color: #38a169; background: #f0fff4; }
.msg.err { color: #e53e3e; background: #fff5f5; }
