.container { padding: 20rpx; padding-bottom: 120rpx; }
.search-bar { display: flex; align-items: center; margin-bottom: 16rpx; }
.search-input { flex: 1; background: #f5f5f5; border-radius: 32rpx; padding: 16rpx 24rpx; font-size: 28rpx; }
.sort-btn { background: #2d8cf0; color: #fff; padding: 14rpx 24rpx; border-radius: 32rpx; font-size: 26rpx; margin-left: 12rpx; white-space: nowrap; }
.category-bar { white-space: nowrap; margin-bottom: 16rpx; }
.cat-tag { display: inline-block; padding: 10rpx 24rpx; margin-right: 12rpx; border-radius: 24rpx; background: #f0f0f0; font-size: 26rpx; }
.cat-tag.active { background: #2d8cf0; color: #fff; }
.vip-badge { background: #fef3cd; color: #856404; padding: 12rpx 20rpx; border-radius: 8rpx; font-size: 26rpx; margin-bottom: 16rpx; text-align: center; }
.card { background: #fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.product { display: flex; align-items: center; }
.p-img { font-size: 60rpx; margin-right: 16rpx; }
.p-info { flex: 1; }
.p-name { font-size: 30rpx; font-weight: bold; }
.p-category { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.p-price-row { display: flex; align-items: center; margin-top: 8rpx; }
.p-price { font-size: 32rpx; color: #e53e3e; font-weight: bold; }
.p-vip-price { font-size: 24rpx; color: #d4a017; margin-left: 12rpx; background: #fff8e1; padding: 2rpx 10rpx; border-radius: 6rpx; }
.p-stock { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.p-action { margin-left: 12rpx; }
.btn-primary { background: #2d8cf0; color: #fff; padding: 14rpx 24rpx; border-radius: 8rpx; font-size: 26rpx; white-space: nowrap; }
.btn-primary.disabled { background: #ccc; }
.cart-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; display: flex; align-items: center; padding: 20rpx 30rpx; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1); }
.cart-icon { font-size: 44rpx; }
.cart-count { background: #e53e3e; color: #fff; font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 20rpx; margin-left: 4rpx; }
.cart-text { flex: 1; text-align: right; font-size: 30rpx; color: #2d8cf0; font-weight: bold; }
.msg { text-align: center; margin-top: 16rpx; font-size: 26rpx; padding: 12rpx; border-radius: 8rpx; }
.msg.success { color: #38a169; background: #f0fff4; }
.msg.err { color: #e53e3e; background: #fff5f5; }
