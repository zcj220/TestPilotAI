.container { padding: 20rpx; padding-bottom: 160rpx; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.title { font-size: 36rpx; font-weight: bold; }
.item-count { font-size: 26rpx; color: #999; }
.empty-cart { text-align: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #999; margin-top: 16rpx; }
.btn-back { display: inline-block; margin-top: 24rpx; background: #2d8cf0; color: #fff; padding: 16rpx 40rpx; border-radius: 32rpx; font-size: 28rpx; }
.cart-item { display: flex; align-items: center; background: #fff; padding: 20rpx; border-radius: 12rpx; margin-bottom: 12rpx; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05); }
.item-img { font-size: 50rpx; margin-right: 16rpx; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; font-weight: bold; }
.item-price { font-size: 24rpx; color: #666; margin-top: 4rpx; }
.item-subtotal { font-size: 26rpx; color: #e53e3e; margin-top: 4rpx; }
.item-remove { font-size: 32rpx; color: #ccc; padding: 10rpx; }
.cart-footer { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 30rpx; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1); }
.subtotal-row { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.subtotal-label { font-size: 28rpx; color: #666; }
.subtotal-value { font-size: 32rpx; color: #e53e3e; font-weight: bold; }
.btn-checkout { background: #2d8cf0; color: #fff; text-align: center; padding: 20rpx; border-radius: 12rpx; font-size: 32rpx; }
.msg { text-align: center; margin-top: 16rpx; font-size: 26rpx; padding: 12rpx; border-radius: 8rpx; }
.msg.success { color: #38a169; background: #f0fff4; }
.msg.err { color: #e53e3e; background: #fff5f5; }
