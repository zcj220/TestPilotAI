<view class="container">
  <view class="header">
    <view class="title">购物车</view>
    <view class="item-count" id="itemCount">共 {{itemCount}} 件</view>
  </view>

  <block wx:if="{{cart.length === 0}}">
    <view class="empty-cart">
      <view class="empty-icon">🛒</view>
      <view class="empty-text">购物车是空的</view>
      <view class="btn-back" bindtap="goBack">去购物</view>
    </view>
  </block>

  <block wx:for="{{cart}}" wx:key="id">
    <view class="cart-item" id="cartItem-{{item.id}}">
      <view class="item-img">{{item.img}}</view>
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-price" id="itemPrice-{{item.id}}">¥{{item.actualPrice}} × {{item.qty}}</view>
        <view class="item-subtotal" id="itemSubtotal-{{item.id}}">小计: ¥{{item.actualPrice * item.qty}}</view>
      </view>
      <view class="item-remove" bindtap="removeItem" data-id="{{item.id}}">✕</view>
    </view>
  </block>

  <view wx:if="{{cart.length > 0}}" class="cart-footer">
    <view class="subtotal-row">
      <view class="subtotal-label">商品小计:</view>
      <view class="subtotal-value" id="subtotal">¥{{subtotal}}</view>
    </view>
    <view class="btn-checkout" bindtap="goCheckout">去结算</view>
  </view>

  <view id="cartMessage" class="msg {{msgClass}}">{{message}}</view>
</view>
