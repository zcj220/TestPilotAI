{
  "app_name": "FreshMart 生鲜超市",
  "description": "生鲜电商小程序，支持商品浏览、搜索排序、会员折扣、购物车、优惠券、配送选择、下单结算等完整购物流程",
  "base_url": "miniprogram://D:/projects/TestPilotAI/miniprogram-demo",
  "version": "2.1",
  "platform": "miniprogram",
  "pages": [
    {
      "url": "/pages/index/index",
      "title": "首页-商品列表",
      "description": "展示所有商品，支持分类筛选、关键词搜索、价格排序。会员用户显示会员价(8折)。可将商品加入购物车。",
      "scenarios": [
        {
          "name": "首页商品展示验证",
          "description": "验证首页加载后商品列表正确显示",
          "steps": [
            {"action": "navigate", "value": "/pages/index/index", "description": "导航到首页"},
            {"action": "screenshot", "description": "截图：首页商品列表"},
            {"action": "assert_text", "target": "#vipBadge", "expected": "会员", "description": "验证会员标识存在"}
          ]
        },
        {
          "name": "加入购物车",
          "description": "将商品加入购物车并验证数量变化",
          "steps": [
            {"action": "navigate", "value": "/pages/index/index", "description": "回到首页"},
            {"action": "click", "target": "#product-1 .btn-primary", "description": "点击第1个商品的加入购物车"},
            {"action": "screenshot", "description": "截图：加入购物车后"}
          ]
        }
      ]
    },
    {
      "url": "/pages/cart/cart",
      "title": "购物车页",
      "description": "展示购物车中所有商品，自动合并相同商品并显示数量。展示每件商品的小计和总计。",
      "scenarios": [
        {
          "name": "购物车验证",
          "description": "验证购物车页面显示正确",
          "steps": [
            {"action": "navigate", "value": "/pages/cart/cart", "description": "导航到购物车"},
            {"action": "screenshot", "description": "截图：购物车页面"},
            {"action": "assert_text", "target": "#subtotal", "expected": "¥", "description": "验证小计金额显示"}
          ]
        }
      ]
    }
  ]
}
