            {
              "action": "navigate",
              "value": "http://localhost:8900/preview/shop-demo/"
            },
            {
              "action": "fill",
              "target": "#loginUser",
              "value": "admin"
            },
            {
              "action": "fill",
              "target": "#loginPass",
              "value": "123456"
            },
            {
              "action": "click",
              "target": "#loginBtn"
            },
            {
              "action": "click",
