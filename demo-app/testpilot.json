{
  "app_name": "Todo + 购物清单（v1.3全面测试）",
  "description": "测试Todo待办和购物清单的核心功能：添加/删除/完成待办项、购物清单增删改、数据持久化、表单验证等",
  "base_url": "http://localhost:8900/preview/demo-app/",
  "version": "1.3",
  "pages": [
    {
      "url": "/",
      "title": "Todo + 购物清单",
      "elements": {
        "Tab-待办": ".tab-btn[data-tab='todo']",
        "Tab-购物": ".tab-btn[data-tab='shop']",
        "待办输入框": "#todoInput",
        "待办添加按钮": "#addBtn",
        "待办列表": "#todoList",
        "待办统计栏": "#stats",
        "筛选-全部": ".filter-btn[data-filter='all']",
        "筛选-未完成": ".filter-btn[data-filter='active']",
        "筛选-已完成": ".filter-btn[data-filter='done']",
        "商品名称": "#shopName",
        "商品单价": "#shopPrice",
        "商品数量": "#shopQty",
        "商品添加按钮": "#shopAddBtn",
        "商品列表": "#shopList",
        "商品种类数": "#shopItemCount",
        "商品总数": "#shopTotalQty",
        "合计金额": "#shopTotalPrice"
      },
      "scenarios": [
        {
          "name": "页面加载与Tab切换",
          "description": "验证首页加载、Tab切换正常工作",
          "steps": [
            {
              "action": "navigate",
              "value": "http://localhost:3001",
              "expected": "页面显示'Todo + 购物清单'标题，默认显示待办事项Tab",
              "description": "打开应用首页"
            },
            {
              "action": "assert_visible",
              "target": ".tab-btn[data-tab='todo']",
              "description": "验证Tab按钮存在"
            },
            {
              "action": "assert_visible",
              "target": "#todoInput",
              "description": "验证待办输入框存在"
            },
            {
              "action": "screenshot",
              "expected": "页面正常加载，显示待办事项Tab内容，Tab按钮'待办事项'处于激活状态",
              "description": "截图记录首页状态"
            },
            {
              "action": "click",
              "target": ".tab-btn[data-tab='shop']",
              "wait_after_ms": 300,
              "description": "切换到购物清单Tab"
            },
            {
              "action": "assert_visible",
              "target": "#shopName",
              "description": "验证购物清单输入框出现"
            },
            {
              "action": "screenshot",
              "expected": "购物清单Tab内容显示，有商品名称、单价、数量输入框和添加按钮",
              "description": "截图记录购物清单Tab"
            },
            {
              "action": "click",
              "target": ".tab-btn[data-tab='todo']",
              "wait_after_ms": 300,
              "description": "切回待办事项Tab"
            }
          ]
        },
        {
          "name": "添加待办事项（智能输入）",
          "description": "使用auto:智能输入测试添加功能",
          "steps": [
            {
              "action": "fill",
              "target": "#todoInput",
              "value": "auto:text:句子",
              "description": "用AI自动生成一段文字作为待办内容"
            },
            {
              "action": "click",
              "target": "#addBtn",
              "wait_after_ms": 200,
              "description": "点击添加按钮"
            },
            {
              "action": "assert_visible",
              "target": ".todo-item",
              "description": "验证待办项出现在列表中"
            },
            {
              "action": "screenshot",
              "expected": "列表中出现一条待办事项，统计栏显示'共1项，已完成0，未完成1'",
              "description": "截图验证添加结果和统计数字是否正确"
            }
          ]
        },
        {
          "name": "添加第二个待办并勾选",
          "description": "测试连续添加和勾选完成",
          "steps": [
            {
              "action": "fill",
              "target": "#todoInput",
              "value": "阅读技术文档1小时",
              "description": "输入第二个待办"
            },
            {
              "action": "click",
              "target": "#addBtn",
              "wait_after_ms": 200,
              "description": "点击添加按钮"
            },
            {
              "action": "click",
              "target": ".todo-item:first-child .todo-checkbox",
              "wait_after_ms": 300,
              "description": "勾选第一个待办为已完成"
            },
            {
              "action": "screenshot",
              "expected": "列表显示2条待办，第一条有删除线样式，统计栏应显示'共2项，已完成1，未完成1'（注意验证数字是否正确）",
              "description": "截图验证完成状态和统计计算"
            }
          ]
        },
        {
          "name": "筛选功能",
          "description": "测试筛选按钮切换",
          "steps": [
            {
              "action": "click",
              "target": ".filter-btn[data-filter='active']",
              "wait_after_ms": 300,
              "description": "点击'未完成'筛选"
            },
            {
              "action": "screenshot",
              "expected": "只显示未完成的待办事项，已完成的不显示",
              "description": "截图记录未完成筛选结果"
            },
            {
              "action": "click",
              "target": ".filter-btn[data-filter='done']",
              "wait_after_ms": 300,
              "description": "点击'已完成'筛选"
            },
            {
              "action": "screenshot",
              "expected": "只显示已完成的待办事项（带删除线），未完成的不显示",
              "description": "截图记录已完成筛选结果"
            },
            {
              "action": "click",
              "target": ".filter-btn[data-filter='all']",
              "wait_after_ms": 200,
              "description": "切回全部显示"
            }
          ]
        },
        {
          "name": "删除待办事项",
          "description": "测试删除功能（已知Bug：删除按钮可能不工作）",
          "steps": [
            {
              "action": "click",
              "target": ".todo-item:first-child .delete-btn",
              "wait_after_ms": 500,
              "description": "点击第一个待办的删除按钮"
            },
            {
              "action": "screenshot",
              "expected": "第一条待办应被删除，列表只剩一条，统计栏数字相应减少",
              "description": "截图验证删除是否生效"
            }
          ]
        },
        {
          "name": "购物清单-添加商品（智能输入）",
          "description": "使用auto:智能输入测试购物清单添加",
          "steps": [
            {
              "action": "click",
              "target": ".tab-btn[data-tab='shop']",
              "wait_after_ms": 300,
              "description": "切换到购物清单Tab"
            },
            {
              "action": "fill",
              "target": "#shopName",
              "value": "苹果",
              "description": "输入商品名称"
            },
            {
              "action": "fill",
              "target": "#shopPrice",
              "value": "5.50",
              "description": "输入单价5.50元"
            },
            {
              "action": "fill",
              "target": "#shopQty",
              "value": "3",
              "description": "输入数量3"
            },
            {
              "action": "click",
              "target": "#shopAddBtn",
              "wait_after_ms": 300,
              "description": "点击添加按钮"
            },
            {
              "action": "assert_visible",
              "target": ".shop-item",
              "description": "验证商品出现在列表中"
            },
            {
              "action": "screenshot",
              "expected": "商品列表显示'苹果 ¥5.50 × 3'，小计应为¥16.50（5.50×3），合计金额也应为¥16.50，商品种类1，商品总数3",
              "description": "截图验证商品添加和小计计算是否正确"
            }
          ]
        },
        {
          "name": "购物清单-多商品计算验证",
          "description": "添加第二个商品，验证汇总计算",
          "steps": [
            {
              "action": "fill",
              "target": "#shopName",
              "value": "牛奶",
              "description": "输入第二个商品名称"
            },
            {
              "action": "fill",
              "target": "#shopPrice",
              "value": "12.80",
              "description": "输入单价12.80元"
            },
            {
              "action": "fill",
              "target": "#shopQty",
              "value": "2",
              "description": "输入数量2"
            },
            {
              "action": "click",
              "target": "#shopAddBtn",
              "wait_after_ms": 300,
              "description": "点击添加按钮"
            },
            {
              "action": "screenshot",
              "expected": "商品列表显示2个商品。苹果小计¥16.50（5.50×3），牛奶小计¥25.60（12.80×2）。汇总：商品种类2，商品总数5（3+2），合计金额¥42.10（16.50+25.60）。请仔细验证每个数字",
              "description": "截图验证多商品的小计和汇总计算"
            }
          ]
        },
        {
          "name": "购物清单-第三个商品（大数额）",
          "description": "添加高单价高数量商品，进一步验证计算",
          "steps": [
            {
              "action": "fill",
              "target": "#shopName",
              "value": "auto:text:人名",
              "description": "用AI生成一个商品名"
            },
            {
              "action": "fill",
              "target": "#shopPrice",
              "value": "auto:number:10-200",
              "description": "AI生成一个10-200之间的随机单价"
            },
            {
              "action": "fill",
              "target": "#shopQty",
              "value": "auto:number:1-10",
              "description": "AI生成一个1-10之间的随机数量"
            },
            {
              "action": "click",
              "target": "#shopAddBtn",
              "wait_after_ms": 300,
              "description": "点击添加按钮"
            },
            {
              "action": "screenshot",
              "expected": "商品列表显示3个商品，每个商品的小计应等于单价×数量，合计金额应等于所有小计之和。请验证每一行的小计是否等于'单价×数量'，合计是否等于所有小计之和",
              "description": "截图验证第三个商品和总计算"
            }
          ]
        },
        {
          "name": "购物清单-删除商品",
          "description": "测试删除商品后汇总数字更新",
          "steps": [
            {
              "action": "click",
              "target": ".shop-item:first-child .shop-delete",
              "wait_after_ms": 300,
              "description": "删除第一个商品（苹果）"
            },
            {
              "action": "screenshot",
              "expected": "苹果被删除，列表只剩2个商品，商品种类变为2，商品总数和合计金额相应减少",
              "description": "截图验证删除后的汇总更新"
            }
          ]
        },
        {
          "name": "页面滚动测试",
          "description": "测试页面整体滚动和布局",
          "steps": [
            {
              "action": "scroll",
              "description": "向下滚动页面"
            },
            {
              "action": "screenshot",
              "expected": "页面滚动正常，没有布局溢出、元素重叠或内容截断问题",
              "description": "截图验证滚动后的页面布局"
            }
          ]
        }
      ]
    }
  ]
}
